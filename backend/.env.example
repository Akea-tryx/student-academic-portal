# Flask
SECRET_KEY=change-this-in-production
DEBUG=True

# SMTP Email (required for email notifications)
# Set SMTP_ENABLED=True and provide Gmail App Password credentials
SMTP_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_character_app_password

# Reminder Scheduler
# REMINDER_INTERVAL_DAYS: days after submission before follow-up reminder is sent
# REMINDER_CHECK_HOURS  : how often the scheduler checks for due reminders
REMINDER_INTERVAL_DAYS=3
REMINDER_CHECK_HOURS=6

# MySQL (for future database integration)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=
MYSQL_DB=academic_portal

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
